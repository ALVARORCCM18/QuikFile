<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_black"
    tools:context=".MainActivity">

    <!-- Barra de Navegación Superior (Azul #0000CC) -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:background="@color/blue_app"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnSettings"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginEnd="10dp"
            android:background="@color/icon_bg_white"
            android:padding="8dp"
            android:src="@drawable/ic_person"
            app:tint="@color/blue_app" />

        <ImageView
            android:id="@+id/btnHome"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginEnd="10dp"
            android:background="@color/icon_bg_white"
            android:padding="8dp"
            android:src="@drawable/ic_home"
            app:tint="@color/blue_app" />

        <ImageView
            android:id="@+id/btnShared"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginEnd="10dp"
            android:background="@color/icon_bg_white"
            android:padding="8dp"
            android:src="@drawable/ic_handshake"
            app:tint="@color/blue_app" />

        <ImageView
            android:id="@+id/btnLogin"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@color/icon_bg_white"
            android:padding="8dp"
            android:src="@drawable/ic_group"
            app:tint="@color/blue_app" />
    </LinearLayout>

    <!-- Barra de Búsqueda -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/searchBar"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_margin="16dp"
        android:background="@drawable/search_bar_background"
        app:layout_constraintEnd_toStartOf="@+id/sideBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <EditText
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:hint="Buscar..."
            android:paddingStart="16dp"
            android:textColor="@color/black"
            android:textColorHint="#999999"
            app:layout_constraintEnd_toStartOf="@+id/searchIcon"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/searchIcon"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginEnd="8dp"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_search"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/blue_app" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Barra lateral azul (decorativa) -->
    <View
        android:id="@+id/sideBar"
        android:layout_width="4dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:background="@color/blue_app"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar" />

    <!-- Área de Scroll para el Contenido -->
    <ScrollView
        android:id="@+id/contentScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:scrollbars="vertical"
        android:fadeScrollbars="false"
        android:scrollbarThumbVertical="@color/blue_app"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/sideBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/searchBar">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:padding="8dp">

            <!-- Carpeta principal -->
            <LinearLayout
                android:id="@+id/itemFolder"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">

                <ImageView
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:src="@drawable/ic_folder"
                    app:tint="@color/icon_bg_white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Carpeta"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Papelera -->
            <LinearLayout
                android:id="@+id/itemTrash"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">

                <ImageView
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:src="@android:drawable/ic_menu_delete"
                    app:tint="@color/icon_bg_white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Papelera"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Espacio extra al final para que el botón no tape el contenido -->
            <View
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_columnSpan="2" />

        </GridLayout>
    </ScrollView>

    <!-- Botón Añadir (Fijo) -->
    <ImageView
        android:id="@+id/btnAdd"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_marginBottom="50dp"
        android:background="@drawable/circle_blue"
        android:padding="24dp"
        android:src="@android:drawable/ic_input_add"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:tint="@color/icon_bg_white" />

</androidx.constraintlayout.widget.ConstraintLayout>
